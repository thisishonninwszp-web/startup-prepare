# 复制本文件为 .env 并填入真实值（与主应用 .env.local 同名同值即可）。
# 爬虫不调 AI、不碰 Auth，只往 external_signals 表写。

# Supabase 项目地址，形如 https://xxxx.supabase.co
SUPABASE_URL=

# Supabase service role 密钥（仅服务端使用，绝不能暴露给前端）
# Supabase 后台 → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Reddit OAuth（可选）。不填则 reddit 源自动跳过，英语圈仍有 hackernews。
# reddit.com/prefs/apps → Create app → 选 "script" → 拿 client id / secret。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Yahoo! JAPAN App ID（知恵袋源，可选）
# 注册：https://e.developer.yahoo.co.jp/register → Client ID
YAHOO_JAPAN_APP_ID=

# 楽天 Web Service App ID（楽天商品源，可选）
# 注册：https://webservice.rakuten.co.jp → applicationId
RAKUTEN_APP_ID=
