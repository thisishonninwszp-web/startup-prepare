{
  "name": "ideaos-crawler",
  "version": "0.1.0",
  "private": true,
  "description": "IdeaOS 独立爬虫子项目：抓取外部痛点/信号 → 写入 Supabase external_signals staging 表。与主应用通过数据库松耦合。",
  "type": "module",
  "scripts": {
    "crawl": "tsx src/cli.ts",
    "watchlist": "tsx src/cli.ts --watchlist",
    "serve": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3"
  },
  "optionalDependencies": {
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
