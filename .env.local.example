# 复制本文件为 .env.local 并填入真实值

# Supabase 项目地址，形如 https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 匿名公钥（前端 Auth 用，可安全暴露在浏览器）
# Supabase 后台 → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role 密钥（仅服务端使用，绝不能暴露给前端）
# Supabase 后台 → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API Key（AI 追问/质疑使用）
# https://aistudio.google.com/apikey 获取
GEMINI_API_KEY=

# 使用的 Gemini 模型名，便于切换
AI_MODEL=gemini-2.5-flash

# Tavily API Key（外部雷达：联网检索产业/政策/竞品信息，可选）
# https://tavily.com 获取，有免费额度。不填则外部雷达功能置灰。
TAVILY_API_KEY=

# Reddit OAuth（外部待审的 reddit 源，可选）
# 不填则 reddit 源自动跳过，英语圈仍有 Hacker News 兜底。
# reddit.com/prefs/apps → Create app → 选 "script" → 拿 client id / secret。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Yahoo! JAPAN App ID（知恵袋源，可选）
# 不填则知恵袋源跳过。注册：https://e.developer.yahoo.co.jp/register → Client ID。
YAHOO_JAPAN_APP_ID=

# 楽天 Web Service App ID（楽天商品源，可选）
# 不填则楽天源跳过。注册：https://webservice.rakuten.co.jp → applicationId。
RAKUTEN_APP_ID=
